{
    "dependencies": {
        "eslint": "^10.0.3",
        "husky": "^9.1.7",
        "prettier": "^3.8.1"
    },
    "scripts": {
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,ts,jsx,tsx}": [
            "eslint --fix --max-warnings=0"
